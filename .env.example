# Choose which vision provider describes the photo.
# Avatar sprites always use OpenAI GPT Image (OPENAI_API_KEY required for images).
# Supported values: openai | gemini
AI_PROVIDER=openai

# Required for photo description (when AI_PROVIDER=openai) and all 8-bit sprites
OPENAI_API_KEY=

# GPT Image model for 8-bit sprites (gpt-image-2, gpt-image-1, gpt-image-1-mini)
OPENAI_IMAGE_MODEL=gpt-image-2

# Required when AI_PROVIDER=gemini (vision only — sprites still use OpenAI)
GEMINI_API_KEY=

# Audio — use FAL (matches tts.py / effects.py) OR direct ElevenLabs.
# FAL is preferred when FAL_KEY is set.
FAL_KEY=
# Fallback voice if the AI does not pick one during photo analysis.
FAL_VOICE=Rachel

# Direct ElevenLabs fallback (only needed if FAL_KEY is not set)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Required on Vercel so QR links work across phones (Vercel Blob storage).
# Create a Blob store in Vercel → Storage, connect it to this project,
# and Vercel will add BLOB_READ_WRITE_TOKEN automatically.
# Private stores work — the app reads blobs server-side via the SDK.
BLOB_READ_WRITE_TOKEN=
